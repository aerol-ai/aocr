FROM node:22-bookworm-slim AS build

WORKDIR /src

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
RUN npx tsc

FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY --from=build /src/build ./build

ENTRYPOINT ["node"]
CMD ["--no-deprecation", "build/server.js", "hooks"]
